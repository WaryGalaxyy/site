<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Обучение PowerPoint</title>
    <style>

					
        body {
            font-family: 'Segoe UI', 'Roboto', 'Inter', system-ui, -apple-system, sans-serif;  
            background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);
            color: #1a2a3a;
            line-height: 1.5;
            padding: 2rem 1rem;
        }


        .container {
            max-width: 1200px;                     													
            margin: 0 auto;
            background: white;
            border-radius: 32px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08), 0 8px 20px rgba(0, 0, 0, 0.05);
            overflow: hidden;
            padding: 2rem 2rem 3rem;
            transition: all 0.3s ease;
        }

        /* ========== ТИПОГРАФИКА ========== */
        h1 {
            font-size: 2.8rem;
            font-weight: 800;
            background: linear-gradient(135deg, #1e6f3f, #2d9c5c);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            margin-bottom: 0.5rem;
            text-align: center;
            letter-spacing: -0.02em;
        }

        .subhead {
            text-align: center;
            color: #5a6e7c;
            font-size: 1.2rem;
            border-bottom: 2px solid #e2e8f0;
            padding-bottom: 1.5rem;
            margin-bottom: 2rem;
        }

        h2 {
            font-size: 2rem;
            font-weight: 700;
            color: #1e4663;
            margin-top: 2.5rem;
            margin-bottom: 1rem;
            padding-left: 1rem;
            border-left: 5px solid #2d9c5c;
        }

        /* первый h2 немного выше */
        h2:first-of-type {
            margin-top: 0.5rem;
        }



        /* декоративный акцент для абзацев */
        .highlight-text {
            background: #f0f9f4;
            padding: 1.2rem 1.5rem;
            border-radius: 24px;
            border-left: 4px solid #2d9c5c;
            margin: 1.5rem 0;
            font-style: normal;
            font-weight: 500;
        }

        /* ========== КАРТОЧКИ ДЛЯ ОБУЧЕНИЯ ========== */
        .cards-grid {
            display: flex;
            gap: 1.8rem;
            flex-wrap: wrap;
            margin: 2rem 0 1rem;
        }

        .card {
            background: #ffffff;
            border-radius: 28px;
            padding: 1.5rem;
            flex: 1;
            min-width: 200px;
            box-shadow: 0 6px 14px rgba(0, 0, 0, 0.03);
            transition: all 0.25s ease;
            border: 1px solid #eef2f5;
        }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 30px -12px rgba(0, 100, 50, 0.15);
            border-color: #cde3d4;
        }

        .card h3 {
            font-size: 1.6rem;
            color: #2d9c5c;
            margin-bottom: 0.5rem;
        }

        .card p {
            text-indent: 0;
            font-size: 0.95rem;
            color: #4a6272;
        }

        /* ========== ВИДЕО ========== */
        .video-wrapper {
            background: #00000008;
            border-radius: 28px;
            padding: 0.5rem;
            margin: 1rem 0 2rem;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
        }

        video {
            width: 100%;
            height: auto;
            border-radius: 24px;
            display: block;
            background: #1e2a32;
        }

        /* ========== НУМЕРОВАННЫЙ СПИСОК (стилизация) ========== */
        .step-list {
            background: #f9fbfd;
            border-radius: 28px;
            padding: 1.5rem 2rem;
            margin: 1.8rem 0;
        }

        .step-list p {
            margin: 0.8rem 0;
            display: flex;
            align-items: baseline;
            gap: 0.75rem;
        }

        .step-number {
            display: inline-block;
            background: #2d9c5c20;
            color: #1e6f3f;
            font-weight: 800;
            width: 28px;
            text-align: center;
            border-radius: 40px;
        }

        /* ========== БАЗОВЫЙ АКЦЕНТ ДЛЯ ССЫЛОК/КНОПОК ========== */
        .btn-excel {
            display: inline-block;
            background: #1e6f3f;
            color: white;
            border-radius: 60px;
            padding: 0.5rem 1.3rem;
            font-weight: 600;
            text-decoration: none;
            transition: 0.2s;
            margin-top: 0.3rem;
        }

        .btn-excel:hover {
            background: #0f562f;
            transform: scale(0.97);
        }

        /* ========== ФУТЕР ========== */
        .footer-note {
            text-align: center;
            margin-top: 3.5rem;
            padding-top: 1.5rem;
            border-top: 1px solid #e2edf2;
            color: #7b8c9b;
            font-size: 0.85rem;
        }


    </style>
</head>
<body>

<div class="container">
